---
import '../styles/tokens.css';

export interface Props {
  title: string;
  description?: string;
  /** Per-line theme id (e.g. "mage"); unset = neutral base theme. */
  theme?: string;
}
const {
  title,
  description = 'Base de conocimiento en español de Mundo de Tinieblas 20.º aniversario.',
  theme,
} = Astro.props;
---

<!doctype html>
<html lang="es" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip" href="#contenido">Saltar al contenido</a>
    <header>
      <nav aria-label="Principal">
        <a class="brand" href="/">Mundo de Tinieblas 20</a>
        <a class="nav-search" href="/buscar">Buscar</a>
      </nav>
    </header>
    <main id="contenido">
      <slot />
    </main>
    <footer>
      <p>
        Base de conocimiento no oficial. Partes del material son propiedad de
        Paradox Interactive AB. Uso personal.
      </p>
    </footer>

    <style is:global>
      * { box-sizing: border-box; }
      html { font-family: var(--font-serif); line-height: 1.65; }
      body {
        margin: 0; background: var(--bg); color: var(--fg);
        display: flex; flex-direction: column; min-height: 100dvh;
        transition: background-color 0.15s ease, color 0.15s ease;
      }
      a { color: var(--accent); }
      a:focus-visible, .skip:focus { outline: 2px solid var(--accent); outline-offset: 2px; }
      .skip {
        position: absolute; left: -999px;
      }
      .skip:focus { left: var(--pad); top: 0.5rem; background: var(--bg); padding: 0.4rem 0.8rem; }
      header, footer { padding: 1rem var(--pad); }
      header { border-bottom: 1px solid var(--border); }
      header nav { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
      .brand { font-weight: 700; letter-spacing: 0.02em; text-decoration: none; color: var(--fg); }
      .nav-search { text-decoration: none; font-weight: 600; color: var(--fg); opacity: 0.85; }
      .nav-search:hover { opacity: 1; text-decoration: underline; }
      main { flex: 1; padding: var(--pad); }
      footer {
        margin-top: 2rem; border-top: 1px solid var(--border);
        color: var(--muted); font-size: 0.85rem;
      }
      main :where(h1, h2, h3, p, ul, ol) { max-width: var(--measure); }

      /* --- Long-form reading typography (books) ------------------------- */
      .prose { max-width: var(--measure); }
      .prose :where(h1, h2, h3, h4) {
        line-height: 1.25; margin-block: 1.5em 0.5em;
      }
      .prose :where(p, ul, ol, table, blockquote) { margin-block: 0 1em; }
      .prose :where(ul, ol) { padding-inline-start: 1.5em; }
      .prose blockquote {
        margin-inline: 0; padding: 0.25em 1em;
        border-inline-start: 3px solid var(--accent);
        color: var(--muted); font-style: italic;
      }
      .prose table {
        width: 100%; border-collapse: collapse; font-size: 0.95em;
        max-width: none;
      }
      .prose :where(th, td) {
        border: 1px solid var(--border); padding: 0.4em 0.6em; text-align: left;
        vertical-align: top;
      }
      .prose th { background: var(--bg-elevated); }
      .prose code {
        font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
        font-size: 0.9em; background: var(--bg-elevated); padding: 0.1em 0.35em;
        border-radius: var(--radius-sm);
      }
    </style>
  </body>
</html>
