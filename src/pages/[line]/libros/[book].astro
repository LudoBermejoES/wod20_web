---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import { bookUrl, lineUrl } from '../../../lib/entities';
import { lineInfo } from '../../../lib/lines';

export async function getStaticPaths() {
  const books = await getCollection('books');
  const byLine = new Map<string, CollectionEntry<'books'>[]>();
  for (const entry of books) {
    const list = byLine.get(entry.data.line) ?? [];
    list.push(entry);
    byLine.set(entry.data.line, list);
  }

  return [...byLine.entries()].flatMap(([line, entries]) => {
    const sorted = [...entries].sort((a, b) => a.data.title_es.localeCompare(b.data.title_es, 'es'));
    return sorted.map((entry, i) => ({
      params: { line, book: entry.data.book_id },
      props: {
        entry,
        prev: i > 0 ? sorted[i - 1] : undefined,
        next: i < sorted.length - 1 ? sorted[i + 1] : undefined,
      },
    }));
  });
}

export interface Props {
  entry: CollectionEntry<'books'>;
  prev?: CollectionEntry<'books'>;
  next?: CollectionEntry<'books'>;
}

const { line } = Astro.params as { line: string };
const info = lineInfo(line)!;
const { entry, prev, next } = Astro.props;
const book = entry.data;

const tocItems = book.chapters.map((chapter) => ({
  title: chapter.title_es,
  anchor: chapter.anchor,
  level: chapter.level,
}));
---

<Layout title={`${book.title_es} — ${info.nombre}`} description={`Lectura: ${book.title_es}.`} theme={line}>
  <Breadcrumb
    items={[
      { label: 'Inicio', href: '/' },
      { label: info.nombre, href: lineUrl(line) },
      { label: book.title_es },
    ]}
  />

  <h1>{book.title_es}</h1>

  <TableOfContents items={tocItems} label="Capítulos" />

  {
    book.chapters.map((chapter) => (
      <section aria-labelledby={chapter.anchor}>
        <h2 id={chapter.anchor}>{chapter.title_es}</h2>
        {chapter.sections.map((section) => {
          const isChapterHeadingSection = section.anchor === chapter.anchor;
          return (
            <div class="prose">
              {!isChapterHeadingSection && <h3 id={section.anchor}>{section.title_es}</h3>}
              <Fragment set:html={section.body_html} />
            </div>
          );
        })}
      </section>
    ))
  }

  <nav class="book-nav" aria-label="Navegación entre libros">
    <span>{prev && <a href={bookUrl(line, prev.data.book_id)}>← {prev.data.title_es}</a>}</span>
    <span>{next && <a href={bookUrl(line, next.data.book_id)}>{next.data.title_es} →</a>}</span>
  </nav>

  <style>
    section {
      margin-block: var(--space-5);
    }
    .book-nav {
      display: flex;
      justify-content: space-between;
      gap: var(--space-3);
      margin-block: var(--space-5) var(--space-3);
      padding-top: var(--space-3);
      border-top: 1px solid var(--border);
      max-width: var(--measure);
    }
  </style>
</Layout>
