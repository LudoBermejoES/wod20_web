---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import StatBlock from '../../../components/StatBlock.astro';
import SourceBadge from '../../../components/SourceBadge.astro';
import Callout from '../../../components/Callout.astro';
import { typeLabelEs, typeSegment } from '../../../lib/taxonomy';
import { bookUrl, lineUrl } from '../../../lib/entities';
import { guideAnchorIndex, resolveGuideHref } from '../../../lib/guide-anchors';
import { lineInfo } from '../../../lib/lines';

type EntityData = CollectionEntry<'entities'>['data'];

export async function getStaticPaths() {
  const entities = await getCollection('entities');
  return entities.map((entry) => ({
    params: { line: entry.data.line, type: entry.data.type, id: entry.data.id },
    props: { entity: entry.data },
  }));
}

export interface Props {
  entity: EntityData;
}

const { line } = Astro.params as { line: string };
const info = lineInfo(line)!;
const { entity } = Astro.props;
const label = typeLabelEs(entity.type);

// Cross-link back to the reading section this entity was extracted from, using the
// entity's own `sources[].section_anchor`. Resolves to the exact guide page + in-page
// anchor via the anchor index; falls back to the book's reading landing when the
// section heading isn't a locatable anchor (demoted/garbled headings).
const guideIndex = await guideAnchorIndex();
let sourceSectionHref: string | undefined;
for (const s of entity.sources ?? []) {
  if (s.section_anchor) {
    const href = resolveGuideHref(guideIndex, entity.line, s.book_id, s.section_anchor);
    if (href) { sourceSectionHref = href; break; }
  }
}
if (!sourceSectionHref && entity.sources?.[0]) {
  sourceSectionHref = bookUrl(entity.line, entity.sources[0].book_id);
}
---

<Layout title={`${entity.name_es} — ${label} — ${info.nombre}`} description={entity.body_es} theme={line}>
  <Breadcrumb
    items={[
      { label: 'Inicio', href: '/' },
      { label: info.nombre, href: lineUrl(line) },
      { label, href: `/${line}/${typeSegment(entity.type)}` },
      { label: entity.name_es },
    ]}
  />

  <p class="type-badge">{label}</p>
  <h1>{entity.name_es}</h1>

  {
    entity.review && (
      <Callout kind="warning" title="Requiere revisión">
        <p>{entity.review.reason ?? 'Las fuentes no coinciden en las mecánicas de esta entrada.'}</p>
      </Callout>
    )
  }

  {entity.body_html ? (
    <div class="body-es prose" set:html={entity.body_html} />
  ) : (
    entity.body_es && <p class="body-es">{entity.body_es}</p>
  )}

  <StatBlock type={entity.type} mechanics={entity.mechanics} mechanicsHtml={entity.mechanics_html} />

  {
    entity.variants && entity.variants.length > 0 && (
      <div class="variants">
        {entity.variants.map((v) => (
          <section class="variant">
            <h3>{v.label}</h3>
            <StatBlock type={entity.type} mechanics={v.mechanics} />
          </section>
        ))}
      </div>
    )
  }

  <h2>Fuentes</h2>
  <ul class="sources">
    {
      entity.sources.map((source) => (
        <li>
          <SourceBadge source={source} />
        </li>
      ))
    }
  </ul>

  {
    sourceSectionHref && (
      <p>
        <a href={sourceSectionHref}>Ver en el manual →</a>
      </p>
    )
  }

  <style>
    .variants { margin: 1em 0; }
    .variant {
      border-left: 3px solid var(--accent, var(--border));
      padding-left: 1em;
      margin: 0.75em 0;
    }
    .variant h3 { margin: 0 0 0.35em; font-size: 1rem; color: var(--muted); }
    .type-badge {
      margin: 0;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--muted);
    }
    .body-es {
      max-width: var(--measure);
    }
    .sources {
      list-style: none;
      margin: 0 0 var(--space-3);
      padding: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5em;
    }
  </style>
</Layout>
