---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import EntityCard from '../../../components/EntityCard.astro';
import { typeLabelEs } from '../../../lib/taxonomy';
import { lineInfo } from '../../../lib/lines';
import { lineUrl } from '../../../lib/entities';

export async function getStaticPaths() {
  const entities = await getCollection('entities');
  const seen = new Set<string>();
  const paths: { params: { line: string; type: string } }[] = [];
  for (const entry of entities) {
    const key = `${entry.data.line}/${entry.data.type}`;
    if (seen.has(key)) continue;
    seen.add(key);
    paths.push({ params: { line: entry.data.line, type: entry.data.type } });
  }
  return paths;
}

const { line, type } = Astro.params as { line: string; type: string };
const info = lineInfo(line)!;
const entities = (await getCollection('entities', (entry) => entry.data.line === line && entry.data.type === type))
  .map((entry) => entry.data)
  .sort((a, b) => a.name_es.localeCompare(b.name_es, 'es'));

const label = typeLabelEs(type);

// Zero-JS "filter": group by the `category` mechanic when the type has one
// (merits/flaws), with plain anchor jump-links. No client JS needed.
const cat = (e: { mechanics?: Record<string, unknown> }) =>
  (e.mechanics as Record<string, unknown> | undefined)?.category as string | undefined;
const categories = [...new Set(entities.map(cat).filter(Boolean))] as string[];
const uncategorized = entities.filter((e) => !cat(e));
// Group by category when any entity has one, but ALWAYS include a catch-all group
// for entities without a category — otherwise a type with a mix (e.g. wonders,
// where only a few carry a category) would silently drop the uncategorized ones.
const grouped =
  categories.length > 0
    ? [
        ...categories
          .sort((a, b) => a.localeCompare(b, 'es'))
          .map((category) => ({
            category,
            items: entities.filter((e) => cat(e) === category),
          })),
        ...(uncategorized.length > 0
          ? [{ category: 'Sin categoría', items: uncategorized }]
          : []),
      ]
    : [{ category: undefined, items: entities }];
---

<Layout title={`${label} — ${info.nombre}`} theme={line}>
  <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: info.nombre, href: lineUrl(line) }, { label }]} />

  <h1>{label}</h1>
  <p>
    {entities.length} entrada{entities.length === 1 ? '' : 's'}.
  </p>

  {
    categories.length > 1 && (
      <nav aria-label="Categorías" class="category-jump">
        {categories.map((category) => (
          <a href={`#cat-${category}`}>{category}</a>
        ))}
      </nav>
    )
  }

  {
    grouped.map(({ category, items }) => (
      <section>
        {category && <h2 id={`cat-${category}`}>{category}</h2>}
        <div class="entity-grid">
          {items.map((entity) => (
            <EntityCard entity={entity} />
          ))}
        </div>
      </section>
    ))
  }

  <style>
    .category-jump {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-block: var(--space-3);
      font-size: 0.9rem;
    }
    .entity-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
      gap: var(--space-3);
      margin-block: var(--space-3) var(--space-5);
    }
  </style>
</Layout>
