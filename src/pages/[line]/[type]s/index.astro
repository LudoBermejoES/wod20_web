---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import EntityCard from '../../../components/EntityCard.astro';
import { typeLabelEs } from '../../../lib/taxonomy';
import { lineInfo } from '../../../lib/lines';
import { lineUrl } from '../../../lib/entities';

export async function getStaticPaths() {
  const entities = await getCollection('entities');
  const seen = new Set<string>();
  const paths: { params: { line: string; type: string } }[] = [];
  for (const entry of entities) {
    const key = `${entry.data.line}/${entry.data.type}`;
    if (seen.has(key)) continue;
    seen.add(key);
    paths.push({ params: { line: entry.data.line, type: entry.data.type } });
  }
  return paths;
}

const { line, type } = Astro.params as { line: string; type: string };
const info = lineInfo(line)!;
const entities = (await getCollection('entities', (entry) => entry.data.line === line && entry.data.type === type))
  .map((entry) => entry.data)
  .sort((a, b) => a.name_es.localeCompare(b.name_es, 'es'));

const label = typeLabelEs(type);

// Zero-JS "filter": group by the `category` mechanic when the type has one
// (merits/flaws), with plain anchor jump-links. No client JS needed.
// `category` groups merits/flaws (a scalar point-category). Some entities (e.g. Gifts
// shared across breeds) now carry a MULTI-VALUE category (a list) after merge unions
// access/classification keys — those aren't a single grouping key, so treat only a
// plain string as a category; anything else falls into the catch-all group.
const cat = (e: { mechanics?: Record<string, unknown> }) => {
  const c = (e.mechanics as Record<string, unknown> | undefined)?.category;
  return typeof c === 'string' ? c : undefined;
};
const categories = [...new Set(entities.map(cat).filter(Boolean))] as string[];
const uncategorized = entities.filter((e) => !cat(e));
// Group by category when any entity has one, but ALWAYS include a catch-all group
// for entities without a category — otherwise a type with a mix (e.g. wonders,
// where only a few carry a category) would silently drop the uncategorized ones.
const grouped =
  categories.length > 0
    ? [
        ...categories
          .sort((a, b) => a.localeCompare(b, 'es'))
          .map((category) => ({
            category,
            items: entities.filter((e) => cat(e) === category),
          })),
        ...(uncategorized.length > 0
          ? [{ category: 'Sin categoría', items: uncategorized }]
          : []),
      ]
    : [{ category: undefined, items: entities }];

// Origin filter (zero-JS, CSS `:has()` + radios). Distinct source books present
// on this page, with a per-book count; a radio per origin hides non-matching
// cards (and empty category sections) via generated CSS rules.
const originCount = new Map<string, { title: string; n: number }>();
for (const e of entities) {
  for (const bid of new Set(e.sources.map((s) => s.book_id))) {
    const title = e.sources.find((s) => s.book_id === bid)?.book_title_es ?? bid;
    const cur = originCount.get(bid) ?? { title, n: 0 };
    cur.n += 1;
    originCount.set(bid, cur);
  }
}
const origins = [...originCount.entries()]
  .map(([id, v]) => ({ id, title: v.title, n: v.n }))
  .sort((a, b) => a.title.localeCompare(b.title, 'es'));
// Generated CSS: for each origin, when its radio is checked, hide cards that
// don't carry that origin and any category section left with no visible card.
const filterCss = origins
  .map(
    (o) => `.type-list:has(#f-${o.id}:checked) .entity-card:not([data-origins~="${o.id}"]){display:none}
.type-list:has(#f-${o.id}:checked) .grp:not(:has(.entity-card[data-origins~="${o.id}"])){display:none}`
  )
  .join('\n');
---

<Layout title={`${label} — ${info.nombre}`} theme={line}>
  <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: info.nombre, href: lineUrl(line) }, { label }]} />

  <h1>{label}</h1>
  <p>
    {entities.length} entrada{entities.length === 1 ? '' : 's'}.
  </p>

  {
    categories.length > 1 && (
      <nav aria-label="Categorías" class="category-jump">
        {categories.map((category) => (
          <a href={`#cat-${category}`}>{category}</a>
        ))}
      </nav>
    )
  }

  <div class="type-list">
    {
      origins.length > 1 && (
        <fieldset class="origin-filter">
          <legend>Filtrar por origen</legend>
          <input type="radio" name="origin" id="f-all" checked />
          <label for="f-all">Todos ({entities.length})</label>
          {origins.map((o) => (
            <>
              <input type="radio" name="origin" id={`f-${o.id}`} />
              <label for={`f-${o.id}`}>{o.title} ({o.n})</label>
            </>
          ))}
        </fieldset>
      )
    }

    {
      grouped.map(({ category, items }) => (
        <section class="grp">
          {category && <h2 id={`cat-${category}`}>{category}</h2>}
          <div class="entity-grid">
            {items.map((entity) => (
              <EntityCard entity={entity} />
            ))}
          </div>
        </section>
      ))
    }
  </div>

  {origins.length > 1 && <style set:html={filterCss} />}

  <style>
    .category-jump {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      margin-block: var(--space-3);
      font-size: 0.9rem;
    }
    .entity-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 20rem), 1fr));
      gap: var(--space-3);
      margin-block: var(--space-3) var(--space-5);
    }
    .origin-filter {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0.5rem 0.75rem;
      margin-block: var(--space-3);
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      align-items: baseline;
    }
    .origin-filter legend {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      padding: 0 0.3rem;
    }
    /* Hide the radios; the labels are the clickable pills. */
    .origin-filter input[type='radio'] {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }
    .origin-filter label {
      font-size: 0.85rem;
      padding: 0.15em 0.7em;
      border: 1px solid var(--border);
      border-radius: 999px;
      cursor: pointer;
      color: var(--muted);
      user-select: none;
    }
    .origin-filter label:hover {
      border-color: var(--accent, currentColor);
    }
    /* The checked radio's label lights up (adjacent-sibling selector). */
    .origin-filter input[type='radio']:checked + label {
      background: var(--accent, var(--fg));
      color: var(--bg);
      border-color: var(--accent, var(--fg));
    }
    .origin-filter input[type='radio']:focus-visible + label {
      outline: 2px solid var(--accent, currentColor);
      outline-offset: 2px;
    }
  </style>
</Layout>
