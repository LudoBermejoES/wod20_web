---
// A single reading page of the per-book guide (add-book-reading-experience 3.2/3.4).
import { getCollection } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import GuideSidebar from '../../../../components/GuideSidebar.astro';
import { lineUrl } from '../../../../lib/entities';
import { lineInfo } from '../../../../lib/lines';
import '../../../../styles/reading.css';

export async function getStaticPaths() {
  const [pages, books] = [await getCollection('guidePages'), await getCollection('guideBooks')];
  const treeByBook = new Map(books.map((b) => [`${b.data.line}/${b.data.book_id}`, b.data]));
  return pages.map((p) => ({
    params: { line: p.data.line, book: p.data.book_id, slug: p.data.slug },
    props: { page: p.data, book: treeByBook.get(`${p.data.line}/${p.data.book_id}`)! },
  }));
}

type GuideBook = Awaited<ReturnType<typeof getCollection<'guideBooks'>>>[number]['data'];
export interface Props { page: any; book: GuideBook }

const { line, book } = Astro.params as { line: string; book: string };
const info = lineInfo(line)!;
const { page, book: bookMeta } = Astro.props as Props;
const base = `/${line}/guia/${book}`;
const isFiction = page.content_type === 'fiction';
const isReference = ['reference', 'glossary'].includes(page.content_type);
// Structural kicker (BLOQUE · CAPÍTULO) above every title — the "unambiguous at a
// glance" cue; fiction gets its own label.
const kicker = isFiction
  ? 'Ficción'
  : [page.block_title, page.chapter && page.chapter !== '—' ? page.chapter : null]
      .filter(Boolean)
      .join(' · ');
---

<Layout title={`${page.title} — ${bookMeta.book_title_es}`} theme={line}>
  <div class="guide-shell">
    <aside class="rail">
      <GuideSidebar
        line={line}
        book={book}
        tree={bookMeta.tree}
        currentSlug={page.slug}
        bookTitle={bookMeta.book_title_es}
      />
    </aside>

    <main class="reading">
      <Breadcrumb
        items={[
          { label: 'Inicio', href: '/' },
          { label: info.nombre, href: lineUrl(line) },
          { label: bookMeta.book_title_es, href: base },
          ...(page.block_title ? [{ label: page.block_title }] : []),
          ...(page.chapter && page.chapter !== '—' ? [{ label: page.chapter }] : []),
          // a split Section shows its parent Part, then its own short title
          ...(page.section && page.part && page.part !== page.chapter
            ? [{ label: page.part }]
            : []),
          { label: page.section ?? page.title },
        ]}
      />

      <article
        class={`prose reading-body${isFiction ? ' is-fiction' : ''}${isReference ? ' is-reference' : ''}`}
        data-content-type={page.content_type}
      >
        <header class="page-head">
          {kicker && <p class="kicker">{kicker}</p>}
          <h1>{page.title}</h1>
        </header>

        {
          page.toc.length > 2 && (
            <nav class="in-page-toc" aria-label="En esta página">
              <p>En esta página</p>
              <ul>
                {page.toc.map((t: { text: string; anchor: string }) => (
                  <li><a href={`#${t.anchor}`}>{t.text}</a></li>
                ))}
              </ul>
            </nav>
          )
        }

        <div class="reading-flow" set:html={page.body_html} />
      </article>

      <nav class="prev-next" aria-label="Navegación de lectura">
        {page.prev ? (
          <a class="pn prev" href={`${base}/${page.prev.slug}`}>
            <span class="pn-label">← Anterior</span>
            <span class="pn-title">{page.prev.title}</span>
          </a>
        ) : <span />}
        {page.next ? (
          <a class="pn next" href={`${base}/${page.next.slug}`}>
            <span class="pn-label">Siguiente →</span>
            <span class="pn-title">{page.next.title}</span>
          </a>
        ) : <span />}
      </nav>
    </main>
  </div>

  <style>
    .guide-shell {
      display: grid;
      grid-template-columns: minmax(0, 16rem) minmax(0, 1fr);
      gap: var(--space-5);
      align-items: start;
      /* Cap + center the whole shell (sidebar + measure + gutter) so on a wide
         monitor the leftover width becomes balanced margins, not a lopsided dead
         zone on the right. ~84rem fits the 16rem rail + 72ch measure + 240px TOC. */
      max-width: 84rem;
      margin-inline: auto;
    }
    /* The rail reads as a quiet panel (recessed tint + hairline), not text
       floating loose beside the column — the persistent book tree earns its
       width by looking considered, not like an unstyled docs sidebar. */
    .rail {
      position: sticky; top: var(--space-3); max-height: calc(100vh - 2rem); overflow-y: auto;
      background: color-mix(in oklab, var(--bg-elevated) 65%, transparent);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: var(--space-3);
    }
    .reading { min-width: 0; }
    .page-head { margin-bottom: var(--space-4); }
    /* type scale, fiction register, tables live in styles/reading.css */
    .in-page-toc {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg-elevated);
      box-shadow: inset 0 1px 0 color-mix(in oklab, var(--fg) 6%, transparent);
      padding: 0.7rem 1.1rem;
      margin-block: var(--space-3);
      font-size: 0.9rem;
    }
    .in-page-toc p {
      margin: 0 0 0.5em; font-family: var(--font-sans); font-weight: 700;
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted);
    }
    .in-page-toc ul { margin: 0; padding: 0; list-style: none; columns: 2; column-gap: var(--space-4); }
    .in-page-toc li { break-inside: avoid; margin-block: 0.2em; }
    .in-page-toc a { text-decoration: none; }
    .in-page-toc a:hover { text-decoration: underline; }
    @media (max-width: 40rem) { .in-page-toc ul { columns: 1; } }

    /* At a wide viewport the mini-TOC leaves the reading column and becomes a
       sticky gutter element beside the measure — an elegant margin note
       rather than a box interrupting the top of every page (§6 of the design
       direction). Below this width it stays inline, as today. The threshold
       accounts for the persistent book-tree rail *plus* the measure *plus*
       the gutter all fitting without cramping any of the three. */
    /* At a wide viewport the mini-TOC becomes a sticky gutter element beside the
       measure. The grid has exactly three REAL children — .page-head, .in-page-toc,
       .reading-flow — each explicitly placed; the rendered body markdown lives
       INSIDE .reading-flow (one grid item), so injected `set:html` content never
       participates in grid auto-placement. (Previously the body was injected as bare
       children and a `:not(.in-page-toc){grid-column:1}` rule — which Astro's scoped
       CSS never stamps onto injected HTML — let paragraphs scatter into column 2.) */
    @media (min-width: 90rem) {
      .reading-body {
        display: grid;
        grid-template-columns: minmax(0, var(--measure)) minmax(200px, 240px);
        grid-template-rows: auto 1fr;
        column-gap: var(--space-5);
        align-items: start;
        /* the base rule caps the article at the measure; here the article is
           measure (text) + a SEPARATE gutter, so the text keeps its full ~72ch
           instead of sharing the 72ch with the TOC. */
        max-width: none;
      }
      .reading-body > .page-head { grid-column: 1; grid-row: 1; }
      .reading-body > .reading-flow { grid-column: 1; grid-row: 2; min-width: 0; }
      .reading-body > .in-page-toc {
        grid-column: 2;
        grid-row: 1 / 3;
        position: sticky;
        top: var(--space-4);
        align-self: start;
        max-height: calc(100vh - var(--space-5));
        overflow-y: auto;
        margin-block: 0;
      }
      .reading-body > .in-page-toc ul { columns: 1; }
    }

    .prev-next {
      display: flex;
      justify-content: space-between;
      gap: var(--space-4);
      margin-top: var(--space-5);
      padding-top: var(--space-3);
      border-top: 1px solid var(--border);
    }
    .pn {
      display: flex; flex-direction: column; gap: 0.3em;
      text-decoration: none; color: var(--fg); max-width: 45%;
    }
    .pn-label {
      font-family: var(--font-sans); font-size: 0.72rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted);
    }
    .pn-title { font-family: var(--font-reading-body); }
    .pn:hover .pn-title { color: var(--accent); }
    .pn.next { align-items: flex-end; text-align: right; margin-left: auto; }
    @media (max-width: 55rem) {
      .guide-shell { grid-template-columns: 1fr; }
      .rail { position: static; max-height: none; }
    }
  </style>
</Layout>
