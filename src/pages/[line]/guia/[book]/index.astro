---
// Per-book reading-site landing/overview page (add-book-reading-experience 3.3).
import { getCollection } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import { lineUrl } from '../../../../lib/entities';
import { lineInfo } from '../../../../lib/lines';
import '../../../../styles/reading.css';

export async function getStaticPaths() {
  const books = await getCollection('guideBooks');
  return books.map((b) => ({
    params: { line: b.data.line, book: b.data.book_id },
    props: { book: b.data },
  }));
}

const { line, book } = Astro.params as { line: string; book: string };
const info = lineInfo(line)!;
const { book: data } = Astro.props;
const base = `/${line}/guia/${book}`;
---

<Layout title={`${data.title_es} — Guía`} theme={line}>
  <Breadcrumb
    items={[
      { label: 'Inicio', href: '/' },
      { label: info.nombre, href: lineUrl(line) },
      { label: 'Guía' },
      { label: data.book_title_es },
    ]}
  />

  <article class="book-landing reading-body">
    <header class="title-page">
      <p class="eyebrow">{info.nombre}</p>
      <p class="kicker">Guía de lectura</p>
      <h1>{data.title_es}</h1>
      <p class="meta">{data.book_title_es} · {data.page_count} secciones de lectura</p>
    </header>

    <nav class="contents" aria-label="Contenidos del libro">
      {
        data.tree.map((blk) => (
          <section class="blk">
            <h2>{blk.block_title}</h2>
            {blk.chapters.map((ch) => (
              <div class="chap">
                {ch.chapter !== '—' && <h3 class="chap-title">{ch.chapter}</h3>}
                <ul>
                  {ch.pages.map((pg) => (
                    <li>
                      <a href={`${base}/${pg.slug}`}>{pg.part ?? pg.title}</a>
                      {pg.content_type === 'fiction' && <span class="tag">ficción</span>}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </section>
        ))
      }
    </nav>
  </article>

  <style>
    .book-landing { max-width: 64rem; }

    /* --- title page: the book's cover, not a fourth card ------------------ */
    .title-page {
      margin-bottom: var(--space-6);
      padding-bottom: var(--space-5);
      border-bottom: 1px solid var(--border);
    }
    .title-page .eyebrow {
      margin: 0 0 1.5em;
      font-family: var(--font-sans);
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--muted);
    }
    .title-page .kicker { margin-bottom: 0.9em; }
    .title-page h1 {
      font-size: clamp(2.2rem, 1.6rem + 3.2vw, 3.75rem);
      letter-spacing: 0.005em;
      max-width: 22ch;
    }
    .title-page .meta {
      margin: 0.9em 0 0;
      font-family: var(--font-sans);
      font-size: 0.9rem;
      color: var(--muted);
    }

    /* --- contents: a printed table of contents, not a grid of cards ------- */
    .contents { display: block; }
    .blk {
      margin-block: 0;
      padding-block: var(--space-4);
    }
    .blk + .blk { border-top: 1px solid var(--border); }
    .blk h2 {
      margin: 0 0 var(--space-3);
      font-family: var(--font-sans);
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent);
      border-bottom: none;
      padding-bottom: 0;
    }
    .chap { margin-block: 0 var(--space-3); }
    .chap:last-child { margin-bottom: 0; }
    h3.chap-title {
      margin: 0 0 0.3em;
      font-size: 1rem;
      font-family: var(--font-reading-body);
      font-weight: 700;
      color: var(--fg);
    }
    .contents ul { list-style: none; padding-left: 0; margin: 0; columns: 2; column-gap: var(--space-5); }
    @media (max-width: 40rem) { .contents ul { columns: 1; } }
    .contents li { margin: 0.3rem 0; break-inside: avoid; line-height: 1.4; }
    .contents a { text-decoration: none; }
    .contents a:hover { color: var(--accent); text-decoration: underline; }
    .tag {
      font-family: var(--font-sans);
      font-size: 0.68em;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0 0.35em;
      margin-left: 0.4em;
    }
  </style>
</Layout>
