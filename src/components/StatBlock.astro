---
// Renders an entity's `mechanics` as a labelled definition list, in the
// field order declared for its type (webgen/taxonomy.json), with Spanish
// labels. Rating-like fields render as dot pips; sphere maps render one
// dot-rating per sphere; everything else renders as plain text.
import DotRating from './DotRating.astro';
import { mechanicLabelEs, sphereLabelEs, TYPE_INFO } from '../lib/taxonomy';

export interface Props {
  type: string;
  mechanics: Record<string, unknown>;
}
const { type, mechanics } = Astro.props;

// Fields rendered as dot ratings when their value is a plain number.
const DOT_FIELDS = new Set([
  'cost',
  'bonus',
  'rating_max',
  'arete_min',
  'arete',
  'quintessence',
  'level',
  'rank',
]);

function toSphereEntries(value: unknown): Array<[string, number]> {
  if (!value || typeof value !== 'object' || Array.isArray(value)) return [];
  return Object.entries(value as Record<string, number>);
}

const knownFields = TYPE_INFO[type]?.mechanical_fields ?? [];
// Show declared fields plus any extra keys, but hide internal `_`-prefixed
// extraction-metadata keys (e.g. `_extraction_note`) — not player-facing.
const extraFields = Object.keys(mechanics).filter(
  (key) => !knownFields.includes(key) && !key.startsWith('_')
);
const fieldKeys = [...knownFields, ...extraFields].filter(
  (key) => mechanics[key] !== undefined && mechanics[key] !== null
);

const cell = (v: unknown): string =>
  v === null || v === undefined ? '' : typeof v === 'object' ? JSON.stringify(v) : String(v);

function isObjectArray(v: unknown): v is Array<Record<string, unknown>> {
  return (
    Array.isArray(v) &&
    v.length > 0 &&
    v.every((x) => x !== null && typeof x === 'object' && !Array.isArray(x))
  );
}

interface Field {
  key: string;
  label: string;
  sphereEntries: Array<[string, number]>;
  numericValue?: number;
  rows?: Array<Record<string, unknown>>; // array-of-objects → table
  columns?: string[];
  arrayValue?: unknown[]; // array of primitives → comma list
  objectValue?: Array<[string, unknown]>; // single object → key/value list
  textValue?: string;
}

const fields: Field[] = fieldKeys.map((key) => {
  const value = mechanics[key];
  // Only treat `spheres` as a dot-pip map when it's actually an object
  // ({Vida: 3}). Lane-B often writes it as a free-text string ("Correspondencia
  // ·· / Fuerzas ·· / Mente ··"); those must fall through to textValue, else the
  // Esferas field renders blank.
  const sphereEntries = key === 'spheres' ? toSphereEntries(value) : [];
  const isSphereMap = sphereEntries.length > 0;
  const numericValue = !isSphereMap && DOT_FIELDS.has(key) && typeof value === 'number' ? value : undefined;
  // Array of objects (e.g. an extracted rules table) → render as a real table,
  // never `[object Object]`. Columns are the union of keys across rows.
  const rows = !isSphereMap && numericValue === undefined && isObjectArray(value) ? value : undefined;
  const columns = rows ? [...new Set(rows.flatMap((r) => Object.keys(r)))] : undefined;
  const arrayValue =
    !isSphereMap && numericValue === undefined && !rows && Array.isArray(value) ? value : undefined;
  const objectValue =
    !isSphereMap && numericValue === undefined && !rows && !arrayValue && value && typeof value === 'object'
      ? Object.entries(value as Record<string, unknown>)
      : undefined;
  const textValue =
    !isSphereMap && numericValue === undefined && !rows && !arrayValue && !objectValue
      ? String(value)
      : undefined;
  return { key, label: mechanicLabelEs(key), sphereEntries, numericValue, rows, columns, arrayValue, objectValue, textValue };
});
---

{
  fields.length > 0 && (
    <dl class="stat-block">
      {fields.map((field) => (
        <>
          <dt>{field.label}</dt>
          <dd>
            {field.sphereEntries.length > 0 && (
              <ul class="spheres">
                {field.sphereEntries.map(([sphere, dots]) => (
                  <li>
                    {sphereLabelEs(sphere)} <DotRating value={dots} label={sphereLabelEs(sphere)} />
                  </li>
                ))}
              </ul>
            )}
            {field.numericValue !== undefined && (
              <DotRating value={field.numericValue} label={field.label} />
            )}
            {field.rows && field.columns && (
              <table class="mech-table">
                <thead>
                  <tr>{field.columns.map((c) => <th>{mechanicLabelEs(c)}</th>)}</tr>
                </thead>
                <tbody>
                  {field.rows.map((row) => (
                    <tr>{field.columns!.map((c) => <td>{cell(row[c])}</td>)}</tr>
                  ))}
                </tbody>
              </table>
            )}
            {field.arrayValue && field.arrayValue.map(cell).join(', ')}
            {field.objectValue && (
              <ul class="obj-list">
                {field.objectValue.map(([k, v]) => (
                  <li>
                    <strong>{mechanicLabelEs(k)}:</strong> {cell(v)}
                  </li>
                ))}
              </ul>
            )}
            {field.textValue}
          </dd>
        </>
      ))}
    </dl>
  )
}

<style>
  /* Stacked label/value: the value always gets the full width, so long lists
     and comma-strings wrap naturally instead of being crammed into a narrow
     column (works in both the narrow card and the wider detail page). */
  .stat-block {
    display: block;
    margin: 0;
    max-width: var(--measure);
  }
  .stat-block dt {
    font-weight: 700;
    color: var(--muted);
    font-size: 0.8em;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 0.5em;
  }
  .stat-block dt:first-child {
    margin-top: 0;
  }
  .stat-block dd {
    margin: 0.1em 0 0;
  }
  .spheres {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.15em;
  }
  .mech-table {
    border-collapse: collapse;
    margin: 0.25em 0;
    font-size: 0.95em;
  }
  .mech-table th,
  .mech-table td {
    border: 1px solid var(--border, #ccc);
    padding: 0.2em 0.5em;
    text-align: left;
    vertical-align: top;
  }
  .mech-table th {
    color: var(--muted);
    font-weight: 700;
  }
  .obj-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.15em;
  }
</style>
