---
// Compact reference card: name, key mechanics, source badges, link to the
// full entity page. Used on `/mage/[type]s` reference-list pages.
import StatBlock from './StatBlock.astro';
import SourceBadge from './SourceBadge.astro';
import { entityUrl } from '../lib/entities';
import { typeLabelEs } from '../lib/taxonomy';

export interface Props {
  entity: {
    id: string;
    type: string;
    line: string;
    name_es: string;
    body_es?: string;
    mechanics: Record<string, unknown>;
    mechanics_html?: Record<string, string | string[]>;
    sources: Array<{ book_id: string; book_title_es?: string; page?: number | string | null }>;
    review?: unknown;
  };
}
const { entity } = Astro.props;
const href = entityUrl(entity.line, entity.type, entity.id);
// Space-separated book ids for the origin filter (an entity may have several).
const originTokens = [...new Set(entity.sources.map((s) => s.book_id))].join(' ');

// A card shows a short PLAIN-TEXT summary, not raw Markdown: drop tables and
// Markdown syntax, then truncate. The full, rendered body lives on the detail page.
function plainExcerpt(md: string, max = 220): string {
  const beforeTable = md.split(/\n\s*\|/)[0]; // stop at the first table row
  let text = beforeTable
    .replace(/^#{1,6}\s+/gm, '') // headings
    .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1') // links → text
    .replace(/[*_`>#|]/g, '') // emphasis/code/blockquote/pipes
    .replace(/\s+/g, ' ')
    .trim();
  if (text.length > max) text = text.slice(0, max).replace(/\s+\S*$/, '') + '…';
  return text;
}
const excerpt = entity.body_es ? plainExcerpt(entity.body_es) : '';
---

<article class="entity-card" data-origins={originTokens}>
  <p class="type-badge">{typeLabelEs(entity.type)}</p>
  <h3><a href={href}>{entity.name_es}</a></h3>
  {excerpt && <p class="excerpt">{excerpt}</p>}
  <StatBlock type={entity.type} mechanics={entity.mechanics} mechanicsHtml={entity.mechanics_html} />
  {
    entity.review && (
      <p class="review-flag" role="status">
        ⚠ Requiere revisión
      </p>
    )
  }
  <ul class="sources">
    {entity.sources.map((source) => (
      <li>
        <SourceBadge source={source} />
      </li>
    ))}
  </ul>
</article>

<style>
  .entity-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-3);
    background: var(--bg-elevated);
    display: grid;
    gap: 0.5rem;
    align-content: start;
  }
  .type-badge {
    margin: 0;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
  }
  .entity-card h3 {
    margin: 0;
    font-size: 1.15rem;
  }
  .entity-card h3 a {
    text-decoration: none;
  }
  .entity-card h3 a:hover {
    text-decoration: underline;
  }
  .excerpt {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .review-flag {
    margin: 0;
    font-size: 0.85rem;
    color: #d97706;
    font-weight: 700;
  }
  .sources {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em;
  }
</style>
